{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "dad40739-078c-4ab4-a462-3633160a59c7"
  },
  "newProjectRoot": "projects",
  "projects": {
    "world-monitor-ui": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": { "skipTests": true },
        "@schematics/angular:component": { "skipTests": true },
        "@schematics/angular:directive": { "skipTests": true },
        "@schematics/angular:guard": { "skipTests": true },
        "@schematics/angular:interceptor": { "skipTests": true },
        "@schematics/angular:pipe": { "skipTests": true },
        "@schematics/angular:resolver": { "skipTests": true },
        "@schematics/angular:service": { "skipTests": true }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",
            "polyfills": [
              "zone.js"
            ],
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "src/styles.css"
            ],
            "allowedCommonJsDependencies": [
              "leaflet"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "world-monitor-ui:build:production"
            },
            "development": {
              "buildTarget": "world-monitor-ui:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}